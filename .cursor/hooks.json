{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/sync-kit-on-session.ps1",
        "timeout": 60
      },
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/bootstrap-obsidian-once.ps1",
        "timeout": 30
      }
    ],
    "beforeShellExecution": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/guard-shell.ps1",
        "timeout": 10
      }
    ],
    "afterAgentResponse": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/rule-candidate-capture.ps1",
        "timeout": 20
      },
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/quality-gate.ps1",
        "timeout": 25
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/kit-start-on-prompt.ps1",
        "matcher": "UserPromptSubmit",
        "timeout": 120
      },
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/rule-approval-gate.ps1",
        "matcher": "UserPromptSubmit",
        "timeout": 20
      }
    ],
    "afterFileEdit": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/ensure-obsidian-git-hook.ps1",
        "matcher": "Write|TabWrite",
        "timeout": 20
      },
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/sync-docs-on-doc-change.ps1",
        "matcher": "Write|TabWrite",
        "timeout": 20
      },
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/guard-completion-claims.ps1",
        "matcher": "Write|TabWrite",
        "timeout": 20
      },
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/guard-delivery-loop.ps1",
        "matcher": "Write|TabWrite",
        "timeout": 20
      }
    ]
  }
}
